---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import Grid from '../../components/Grid.astro';
import Icon from '../../components/Icon.astro';
import Pill from '../../components/Pill.astro';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const tags = [...new Set(posts.flatMap((post) => post.data.tags))];
---

<BaseLayout title="Blog | Portfolio" description="디자인과 개발에 관한 생각과 경험을 공유합니다.">
	<div class="stack gap-20">
		<div class="wrapper">
			<header class="hero">
				<Hero
					title="Blog"
					tagline="디자인과 개발에 관한 생각과 경험을 공유합니다."
					align="start"
				/>
			</header>
		</div>

		<main class="wrapper">
			<!-- Tags -->
			<section class="tags-section">
				<h2>Tags</h2>
				<div class="tags">
					{tags.map((tag) => (
						<Pill><Icon icon="tag" size="1em" /> {tag}</Pill>
					))}
				</div>
			</section>

			<!-- Posts Grid -->
			<section class="posts-section">
				<h2>Recent Posts</h2>
				<Grid variant="offset">
					{posts.map((post) => (
						<li>
							<a class="post-card" href={`/blog/${post.id}/`}>
								<div class="post-content">
									<span class="post-date">
										{post.data.publishDate.toLocaleDateString('ko-KR', {
											year: 'numeric',
											month: 'long',
											day: 'numeric',
										})}
									</span>
									<h3 class="post-title">{post.data.title}</h3>
									<p class="post-description">{post.data.description}</p>
									<div class="post-tags">
										{post.data.tags.slice(0, 3).map((tag) => (
											<span class="tag">{tag}</span>
										))}
									</div>
								</div>
							</a>
						</li>
					))}
				</Grid>
			</section>
		</main>
	</div>
</BaseLayout>

<style>
	.hero {
		margin-bottom: 2rem;
	}

	.tags-section {
		margin-bottom: 4rem;
	}

	.tags-section h2 {
		font-size: var(--text-xl);
		margin-bottom: 1rem;
		color: var(--text-primary);
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
	}

	.posts-section h2 {
		font-size: var(--text-2xl);
		margin-bottom: 2rem;
		color: var(--text-primary);
	}

	.post-card {
		display: flex;
		flex-direction: column;
		background: var(--bg-secondary);
		border: 1px solid var(--border-color);
		border-radius: 1rem;
		overflow: hidden;
		transition: all var(--theme-transition);
		text-decoration: none;
		height: 100%;
	}

	.post-card:hover {
		box-shadow: var(--shadow-md);
		transform: translateY(-4px);
		border-color: var(--matcha-primary);
	}

	.post-content {
		padding: 1.5rem;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.post-date {
		font-size: var(--text-sm);
		color: var(--text-muted);
	}

	.post-title {
		font-size: var(--text-lg);
		color: var(--text-primary);
		margin: 0;
		line-height: 1.3;
	}

	.post-description {
		font-size: var(--text-base);
		color: var(--text-secondary);
		line-height: 1.5;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.post-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-top: auto;
		padding-top: 1rem;
	}

	.tag {
		display: inline-flex;
		align-items: center;
		gap: 0.25rem;
		padding: 0.25rem 0.5rem;
		border-radius: 9999px;
		font-size: 0.75rem;
		font-weight: 500;
		background: var(--bg-tertiary);
		color: var(--text-secondary);
	}

	@media (min-width: 50em) {
		.post-card {
			border-radius: 1.5rem;
		}

		.post-content {
			padding: 2rem;
		}

		.post-title {
			font-size: var(--text-xl);
		}
	}
</style>

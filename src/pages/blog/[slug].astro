---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import Icon from '../../components/Icon.astro';
import Pill from '../../components/Pill.astro';

interface Props {
	entry: CollectionEntry<'blog'>;
}

// This is a dynamic route that generates a page for every Markdown file in src/content/blog/
export async function getStaticPaths() {
	const blog = await getCollection('blog');
	return blog.map((entry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const { title, description, publishDate, tags, img, img_alt } = entry.data;
---

<BaseLayout title={title} description={description}>
	<div class="stack gap-20">
		<div class="wrapper">
			<header class="hero">
				<div class="hero-content">
					<span class="post-date">
						{publishDate.toLocaleDateString('ko-KR', {
							year: 'numeric',
							month: 'long',
							day: 'numeric',
						})}
					</span>
					<Hero title={title} align="start">
						<p class="description">{description}</p>
						<div class="tags">
							{tags.map((tag) => (
								<Pill><Icon icon="tag" size="1em" /> {tag}</Pill>
							))}
						</div>
					</Hero>
				</div>
			</header>
		</div>

		<main class="wrapper">
			{img && (
				<img src={img} alt={img_alt || ''} class="post-image" />
			)}
			
			<div class="content">
				<Content />
			</div>
		</main>
	</div>
</BaseLayout>

<style>
	.hero {
		margin-bottom: 2rem;
	}

	.hero-content {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.post-date {
		font-size: var(--text-sm);
		color: var(--text-muted);
	}

	.description {
		font-size: var(--text-lg);
		color: var(--text-secondary);
		line-height: 1.6;
		max-width: 60ch;
	}

	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		margin-top: 1rem;
	}

	.post-image {
		width: 100%;
		max-height: 400px;
		object-fit: cover;
		border-radius: 1rem;
		margin-bottom: 3rem;
	}

	.content {
		max-width: 65ch;
		margin: 0 auto;
	}

	.content :global(h2) {
		font-size: var(--text-2xl);
		margin-top: 3rem;
		margin-bottom: 1rem;
		color: var(--text-primary);
	}

	.content :global(h3) {
		font-size: var(--text-xl);
		margin-top: 2rem;
		margin-bottom: 0.75rem;
		color: var(--text-primary);
	}

	.content :global(p) {
		font-size: var(--text-base);
		line-height: 1.8;
		color: var(--text-secondary);
		margin-bottom: 1.5rem;
	}

	.content :global(ul),
	.content :global(ol) {
		margin-bottom: 1.5rem;
		padding-left: 1.5rem;
	}

	.content :global(li) {
		margin-bottom: 0.5rem;
		color: var(--text-secondary);
	}

	.content :global(code) {
		background: var(--bg-tertiary);
		padding: 0.2em 0.4em;
		border-radius: 0.25rem;
		font-family: monospace;
		font-size: 0.9em;
	}

	.content :global(pre) {
		background: var(--bg-tertiary);
		padding: 1rem;
		border-radius: 0.5rem;
		overflow-x: auto;
		margin-bottom: 1.5rem;
	}

	.content :global(pre code) {
		background: none;
		padding: 0;
	}

	.content :global(blockquote) {
		border-left: 4px solid var(--matcha-primary);
		padding-left: 1rem;
		margin: 1.5rem 0;
		color: var(--text-muted);
		font-style: italic;
	}

	@media (min-width: 50em) {
		.post-image {
			border-radius: 1.5rem;
			max-height: 500px;
		}
	}
</style>
